stock bool:OPCore_GetInteriorDoorPos(index, &Float:x, &Float:y, &Float:z, &int)
{
    if(index < 0 || index >= MAX_INTERIORS) return false;

    x = gsc_InteriorData[index][INTERIOR_DOOR_POSX];
    y = gsc_InteriorData[index][INTERIOR_DOOR_POSY];
    z = gsc_InteriorData[index][INTERIOR_DOOR_POSZ];
    int = gsc_InteriorData[index][INTERIOR_INTERIOR_ID];
    return true;
}

stock bool:OPCore_GetInteriorPos(index, &Float:x, &Float:y, &Float:z, &Float:angle)
{
    if(index < 0 || index >= MAX_INTERIORS) 
        return false;
    
    x = g_InteriorData[index][INTERIOR_POS_X];
    y = g_InteriorData[index][INTERIOR_POS_Y];
    z = g_InteriorData[index][INTERIOR_POS_Z];
    angle = g_InteriorData[index][INTERIOR_ANGEL];
    return true;
}

stock bool:OPCore_GotoInterior(playerid, index, worldid = 0)
{
    if(index < 0 || index >= MAX_INTERIORS) return false;

    SetPlayerPos(playerid, gsc_InteriorData[index][INTERIOR_POS_X], gsc_InteriorData[index][INTERIOR_POS_Y], gsc_InteriorData[index][INTERIOR_POS_Z] + 1.0);
    SetPlayerFacingAngle(playerid, gsc_InteriorData[index][INTERIOR_ANGEL]);
    SetPlayerInterior(playerid, gsc_InteriorData[index][INTERIOR_INTERIOR_ID]);
    SetPlayerVirtualWorld(playerid, worldid);

    SetCameraBehindPlayer(playerid);

    GameTextForPlayer(playerid, "%s", 3500, 8, gsc_InteriorData[index][INTERIOR_NAME]);
    return true;
}